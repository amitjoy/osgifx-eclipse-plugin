<plugin>
	<!-- Commands -->
	<extension point="org.eclipse.ui.commands">
		<command
			id="com.osgifx.eclipse.commands.launch"
			name="Launch OSGi.fx"
			description="Open OSGi.fx Connection Manager"/>
	</extension>
	
	<!-- Handlers -->
	<extension point="org.eclipse.ui.handlers">
		<handler
			commandId="com.osgifx.eclipse.commands.launch"
			class="com.osgifx.eclipse.ui.handlers.ToolbarLaunchHandler"/>
	</extension>
	
	<!-- Toolbar and Menus -->
	<extension point="org.eclipse.ui.menus">
		<menuContribution locationURI="toolbar:org.eclipse.ui.main.toolbar?after=additions">
			<toolbar id="com.osgifx.eclipse.toolbar">
				<command
					commandId="com.osgifx.eclipse.commands.launch"
					icon="icons/icon.png"
					label="OSGi.fx"
					tooltip="Manage OSGi.fx Connections"
					id="com.osgifx.eclipse.toolbar.launch"/>
			</toolbar>
		</menuContribution>
		<menuContribution locationURI="menu:help?after=additions">
			<command
				commandId="com.osgifx.eclipse.commands.launch"
				label="Open OSGi.fx..."
				icon="icons/icon.png">
			</command>
		</menuContribution>
		<menuContribution locationURI="menu:window?after=additions">
			<command
				commandId="com.osgifx.eclipse.commands.launch"
				label="OSGi.fx Console"
				icon="icons/icon.png">
			</command>
		</menuContribution>
	</extension>
	
	<!-- Preferences -->
	<extension point="org.eclipse.ui.preferencePages">
		<page
			id="com.osgifx.eclipse.preferences"
			name="OSGi.fx"
			class="com.osgifx.eclipse.internal.preferences.OsgifxPreferencePage"/>
	</extension>
</plugin>
